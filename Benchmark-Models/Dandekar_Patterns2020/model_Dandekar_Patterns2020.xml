<?xml version="1.0" encoding="UTF-8"?>
<sbml xmlns="http://www.sbml.org/sbml/level3/version2/core"
      level="3"
      version="2">
  <model id="Dandekar_Patterns2020"
         name="Dandekar_Patterns2020"
         substanceUnits="person"
         timeUnits="day"
         extentUnits="person">

    <notes>
      <body xmlns="http://www.w3.org/1999/xhtml">
        <p>
          SIR-type universal differential equation model for COVID-19 spread,
          based on Dandekar, Rackauckas, and Barbastathis, Patterns, 2020.
          The parameter quarantine_rate is intended to be assigned dynamically
          from the PEtab-SciML neural-network output net1_output1.
        </p>
      </body>
    </notes>

    <annotation>
      <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
               xmlns:bqmodel="http://biomodels.net/model-qualifiers/">
        <rdf:Description rdf:about="#Dandekar_Patterns2020">
          <bqmodel:isDescribedBy>
            <rdf:Bag>
              <rdf:li rdf:resource="https://identifiers.org/doi/10.1016/j.patter.2020.100145"/>
              <rdf:li rdf:resource="https://identifiers.org/pubmed/33225319"/>
            </rdf:Bag>
          </bqmodel:isDescribedBy>
        </rdf:Description>
      </rdf:RDF>
    </annotation>

    <listOfUnitDefinitions>
      <unitDefinition id="person" name="person">
        <listOfUnits>
          <unit kind="item" exponent="1" scale="0" multiplier="1"/>
        </listOfUnits>
      </unitDefinition>

      <unitDefinition id="day" name="day">
        <listOfUnits>
          <unit kind="second" exponent="1" scale="0" multiplier="86400"/>
        </listOfUnits>
      </unitDefinition>

      <unitDefinition id="per_day" name="per day">
        <listOfUnits>
          <unit kind="second" exponent="-1" scale="0" multiplier="1.1574074074074073e-5"/>
        </listOfUnits>
      </unitDefinition>
    </listOfUnitDefinitions>

    <listOfCompartments>
      <compartment id="population"
                   name="population"
                   spatialDimensions="0"
                   size="1"
                   constant="true"/>
    </listOfCompartments>

    <listOfSpecies>
      <species id="S"
               name="susceptible"
               compartment="population"
               initialAmount="66000000"
               substanceUnits="person"
               hasOnlySubstanceUnits="true"
               boundaryCondition="false"
               constant="false"/>

      <species id="I"
               name="infected"
               compartment="population"
               initialAmount="762"
               substanceUnits="person"
               hasOnlySubstanceUnits="true"
               boundaryCondition="false"
               constant="false"/>

      <species id="R"
               name="recovered"
               compartment="population"
               initialAmount="26"
               substanceUnits="person"
               hasOnlySubstanceUnits="true"
               boundaryCondition="false"
               constant="false"/>

      <species id="T"
               name="quarantined"
               compartment="population"
               initialAmount="10"
               substanceUnits="person"
               hasOnlySubstanceUnits="true"
               boundaryCondition="false"
               constant="false"/>
    </listOfSpecies>

    <listOfParameters>
      <parameter id="N"
                 name="population_size"
                 value="66000000"
                 units="person"
                 constant="true"/>

      <parameter id="beta"
                 name="infection_rate"
                 units="per_day"
                 constant="true"/>

      <parameter id="gamma"
                 name="recovery_rate"
                 units="per_day"
                 constant="true"/>

      <parameter id="delta"
                 name="quarantine_release_rate"
                 units="per_day"
                 constant="true"/>

      <parameter id="quarantine_rate"
                 name="neural_network_quarantine_rate"
                 units="per_day"
                 constant="true"/>
    </listOfParameters>

    <listOfRules>
      <rateRule variable="S">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply>
            <minus/>
            <apply>
              <divide/>
              <apply>
                <times/>
                <ci> beta </ci>
                <ci> S </ci>
                <ci> I </ci>
              </apply>
              <ci> N </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <rateRule variable="I">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply>
            <minus/>
            <apply>
              <minus/>
              <apply>
                <divide/>
                <apply>
                  <times/>
                  <ci> beta </ci>
                  <ci> S </ci>
                  <ci> I </ci>
                </apply>
                <ci> N </ci>
              </apply>
              <apply>
                <times/>
                <ci> gamma </ci>
                <ci> I </ci>
              </apply>
            </apply>
            <apply>
              <times/>
              <ci> quarantine_rate </ci>
              <ci> I </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <rateRule variable="R">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply>
            <plus/>
            <apply>
              <times/>
              <ci> gamma </ci>
              <ci> I </ci>
            </apply>
            <apply>
              <times/>
              <ci> delta </ci>
              <ci> T </ci>
            </apply>
          </apply>
        </math>
      </rateRule>

      <rateRule variable="T">
        <math xmlns="http://www.w3.org/1998/Math/MathML">
          <apply>
            <minus/>
            <apply>
              <times/>
              <ci> quarantine_rate </ci>
              <ci> I </ci>
            </apply>
            <apply>
              <times/>
              <ci> delta </ci>
              <ci> T </ci>
            </apply>
          </apply>
        </math>
      </rateRule>
    </listOfRules>
  </model>
</sbml>